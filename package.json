			"./index.ts"
		],
		"skills": [
			"./skills"
		]
	},
	"dependencies": {
		"@mozilla/readability": "^0.6.0",
		"jsdom": "^24.0.0",
		"turndown": "^7.1.2"
	},
	"peerDependencies": {
